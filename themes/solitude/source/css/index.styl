@charset "UTF-8"

// CSS Prefix Configuration
if hexo-config('css_prefix')
  @import 'nib'

@import "third_party/snackbar.min.css"
// project
@import "var.styl"
@import '_global/*'
@import '_layout/*'
@import '_page/index.styl'
@import '_post/index.styl'
@import '_mode/*'

// highlight
@import '_highlight/index'

// search
if hexo-config('search.enable')
  if hexo-config('search.type') == 'algolia'
    @import '_search/algolia-search'
  else if hexo-config('search.type') == 'local'
    @import '_search/local-search'

// tags plugin
@import "_tags/*"

// comment
if hexo-config('comment.use')
  @import '_comments/comment.styl'

// components
@import '_components/index'

/* 整体归档布局 */
#archive .article-sort {
    display: flex;
    flex-direction: column;
    gap: 10px; /* 文章之间的间距 */
}

/* ================= 年份分组样式 ================= */
.archive-year-group {
    margin-bottom: 30px; /* 不同年份组之间的间距 */
}

.archive-year-title {
    position: relative;
    font-size: 1.8rem; /* 年份字体大小 */
    font-weight: bold;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    color: #fff; /* 或你主题的主文字颜色 */
}

/* 年份下面的蓝色横线 */
.archive-year-title .archive-year-line {
    display: inline-block;
    margin-left: 10px;
    width: 30px;
    height: 3px;
    background-color: #00b4d8; /* 图片中的亮蓝色，可自定义 */
    border-radius: 2px;
}

/* ================= 单篇文章条目样式 ================= */
.archive-post-item {
    display: flex;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px dashed rgba(255, 255, 255, 0.1); /* 列表底部虚线 */
    transition: transform 0.2s;
}

.archive-post-item:hover {
    transform: translateX(5px); /* 鼠标悬浮稍微右移效果 */
}

/* 日期样式 */
.archive-post-date {
    font-family: monospace, sans-serif;
    color: #a9a9b3; /* 灰色日期 */
    font-size: 0.9rem;
    margin-right: 20px;
    min-width: 60px; /* 保证日期对齐 */
    display: inline-block;
}

/* 标题样式 */
.archive-post-title {
    color: #c4c4cc; /* 较亮的灰色，有时是白色 */
    text-decoration: none;
    font-size: 1rem;
    transition: color 0.3s;
}

.archive-post-title:hover {
    color: #00b4d8; /* 悬停变为蓝色 */
    text-decoration: underline;
}