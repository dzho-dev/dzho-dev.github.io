#archive
  .archive-year-group
    margin-bottom: 2.5rem

  .archive-year-title
    position: relative
    font-size: 2rem
    font-weight: bold
    margin-bottom: 1.8rem
    color: #fff
    display: flex
    align-items: center

    &::after
      content: ''
      position: absolute
      bottom: -6px
      left: 0
      width: 32px
      height: 4px
      background: #00a8ff
      border-radius: 2px

  .archive-post-item
    display: flex
    align-items: center
    padding: 12px 0
    border-bottom: none
    transition: transform 0.2s ease

    &:hover
      transform: translateX(6px)

    .archive-post-date
      font-family: 'JetBrains Mono', 'Consolas', monospace
      color: #88909b
      font-size: 0.95rem
      
      // 纯数字日期只有5个字符，宽度缩小更紧凑好看
      min-width: 50px    
      width: 50px
      text-align: right  
      margin-right: 20px 
      display: inline-block

    .archive-post-title
      color: #c0c0c0
      font-size: 1rem
      text-decoration: none
      transition: color 0.2s
      flex: 1

      &:hover
        color: #00a8ff